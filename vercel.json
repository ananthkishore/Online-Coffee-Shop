{
  "version": 2,
  "builds": [
    {
      "src": "Coffee shop/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/Coffee shop/frontend/dist/index.html" }
  ]
}
